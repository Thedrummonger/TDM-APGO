<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APGo_Custom.SettingsPage"
             Title="Connection Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Connection Settings" FontSize="20" FontAttributes="Bold" />
            <Label Text="Server Address:" />
            <Entry x:Name="ServerEntry" 
                   Placeholder="archipelago.gg" 
                   TextChanged="OnServerChanged" />
            <Label Text="Port:" />
            <Entry x:Name="PortEntry" 
                   Placeholder="38281" 
                   Keyboard="Numeric"
                   TextChanged="OnPortChanged" />
            <Label Text="Slot Name:" />
            <Entry x:Name="SlotEntry" 
                   Placeholder="Player1"
                   TextChanged="OnSlotChanged" />
            <Label Text="Password (optional):" />
            <Entry x:Name="PasswordEntry" 
                   Placeholder="Leave blank if none" 
                   IsPassword="True"
                   TextChanged="OnPasswordChanged" />
            <BoxView HeightRequest="2" Color="Gray" Margin="0,10,0,10" />
            <Label x:Name="ProximityLabel" Text="Proximity Range:" />
            <Slider x:Name="ProximitySlider"
                    Minimum="5"
                    Maximum="60"
                    ValueChanged="OnProximityChanged" />
            <BoxView HeightRequest="2" Color="Gray" Margin="0,10,0,10" />
            <Label Text="Data Management" FontSize="20" FontAttributes="Bold" />

            <!-- Valid Locations section -->
            <Label Text="Valid Locations" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="5">
                <Button Grid.Column="0"
                        Text="Clear" 
                        Clicked="OnClearValidLocationsClicked"
                        BackgroundColor="Red"
                        TextColor="White" />
                <Button Grid.Column="1"
                        Text="Export" 
                        Clicked="OnExportValidLocationsClicked"
                        BackgroundColor="Orange"
                        TextColor="White" />
                <Button Grid.Column="2"
                        Text="Load" 
                        Clicked="OnLoadValidLocationsClicked"
                        BackgroundColor="Green"
                        TextColor="White" />
            </Grid>

            <!-- Seed Data section -->
            <Label Text="Seed Data" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="5">
                <Button Grid.Column="0"
                        Text="Clear" 
                        Clicked="OnClearSeedDataClicked"
                        BackgroundColor="Red"
                        TextColor="White" />
                <Button Grid.Column="1"
                        Text="Export" 
                        Clicked="OnExportSeedDataClicked"
                        BackgroundColor="Orange"
                        TextColor="White" />
                <Button Grid.Column="2"
                        Text="Load" 
                        Clicked="OnLoadSeedDataClicked"
                        BackgroundColor="Green"
                        TextColor="White" />
            </Grid>

            <BoxView HeightRequest="2" Color="Gray" Margin="0,10,0,10" />
            <Button Text="Close" 
                    Clicked="OnCloseClicked"
                    BackgroundColor="Gray"
                    TextColor="White" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>