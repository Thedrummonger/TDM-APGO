<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APGo_Custom.SettingsPage"
             Title="Connection Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Connection Settings" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="Close" 
                        Clicked="OnCloseClicked"
                        BackgroundColor="Gray"
                        TextColor="White"
                        WidthRequest="80" />
            </Grid>
            <Label Text="Server Address:" />
            <Entry x:Name="ServerEntry" 
                   Placeholder="archipelago.gg" 
                   TextChanged="OnServerChanged" />
            <Label Text="Port:" />
            <Entry x:Name="PortEntry" 
                   Placeholder="38281" 
                   Keyboard="Numeric"
                   TextChanged="OnPortChanged" />
            <Label Text="Slot Name:" />
            <Entry x:Name="SlotEntry" 
                   Placeholder="Player1"
                   TextChanged="OnSlotChanged" />
            <Label Text="Password (optional):" />
            <Entry x:Name="PasswordEntry" 
                   Placeholder="Leave blank if none" 
                   IsPassword="True"
                   TextChanged="OnPasswordChanged" />
            <BoxView HeightRequest="2" Color="Gray" Margin="0,10,0,10" />
            <Label Text="User Settings" FontSize="20" FontAttributes="Bold" />
            <Label x:Name="ProximityLabel" Text="Proximity Range:" />
            <Slider x:Name="ProximitySlider"
                    Minimum="5"
                    Maximum="60"
                    ValueChanged="OnProximitySliderChanged" />
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,5,0,0">
                <Switch x:Name="UseYamlMaxDistanceSwitch"
                        Grid.Column="0"
                        Toggled="OnUseMaxDistanceToggled" />
                <Label Grid.Column="1"
                       Text="Use YAML Max Distance"
                       VerticalOptions="Center" />
            </Grid>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Switch x:Name="UseYamlMinDistanceSwitch"
                        Grid.Column="0"
                        Toggled="OnUseMinDistanceToggled" />
                <Label Grid.Column="1"
                       Text="Use YAML Min Distance"
                       VerticalOptions="Center" />
            </Grid>
            <BoxView HeightRequest="2" Color="Gray" Margin="0,10,0,10" />
            <Label Text="Data Management" FontSize="20" FontAttributes="Bold" />

            <!-- Valid Locations section -->
            <Label Text="Valid Locations" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="5">
                <Button Grid.Column="0"
                        Text="Clear" 
                        Clicked="OnClearValidLocationsClicked"
                        BackgroundColor="Grey"
                        TextColor="White" />
                <Button Grid.Column="1"
                        Text="Export" 
                        Clicked="OnExportValidLocationsClicked"
                        BackgroundColor="Grey"
                        TextColor="White" />
                <Button Grid.Column="2"
                        Text="Load" 
                        Clicked="OnLoadValidLocationsClicked"
                        BackgroundColor="Grey"
                        TextColor="White" />
            </Grid>

            <!-- Seed Data section -->
            <Label Text="Seed Data" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="5">
                <Button Grid.Column="0"
                        Text="Clear" 
                        Clicked="OnClearSeedDataClicked"
                        BackgroundColor="Grey"
                        TextColor="White" />
                <Button Grid.Column="1"
                        Text="Export" 
                        Clicked="OnExportSeedDataClicked"
                        BackgroundColor="Grey"
                        TextColor="White" />
                <Button Grid.Column="2"
                        Text="Load" 
                        Clicked="OnLoadSeedDataClicked"
                        BackgroundColor="Grey"
                        TextColor="White" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>