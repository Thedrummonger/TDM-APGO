<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APGo_Custom.MainPage">
    <Grid x:Name="MainGrid" RowDefinitions="2*,*">
        <!-- Map takes top 2/3 -->
        <WebView x:Name="MapWebView" Grid.Row="0" />
        <!-- Chat area takes bottom 1/3 -->
        <Grid x:Name="ChatGrid" Grid.Row="1" RowDefinitions="*,Auto" BackgroundColor="#E0E0E0" RowSpacing="0">
            <!-- Separator line at top of chat -->
            <BoxView Grid.Row="0" 
                     VerticalOptions="Start" 
                     HeightRequest="2" 
                     BackgroundColor="Black" 
                     ZIndex="1" />
            <!-- Chat messages -->
            <ScrollView x:Name="ChatScrollView" 
                       Grid.Row="0" 
                       BackgroundColor="Gray" 
                       Scrolled="OnChatScrolled"
                       Margin="0,2,0,0">
                <VerticalStackLayout x:Name="ChatMessages" Padding="2" Spacing="0" />
            </ScrollView>
            <!-- Input area -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Padding="10" BackgroundColor="#F5F5F5">
                <Entry x:Name="ChatInput" 
                       Grid.Column="0" 
                       Placeholder="Type a message..."
                       TextColor="Black"
                       PlaceholderColor="Gray"
                       BackgroundColor="White"
                       VerticalOptions="Center" />
                <Button Grid.Column="1" 
                        Text="Send" 
                        Clicked="OnSendMessageClicked"
                        Margin="5,0,0,0"
                        WidthRequest="60"
                        Padding="0"/>
            </Grid>
        </Grid>
        <!-- Connection status button -->
        <Button 
            x:Name="ConnectionButton"
            Text="🔴"
            FontSize="20"
            WidthRequest="50"
            HeightRequest="50"
            CornerRadius="25"
            BackgroundColor="White"
            TextColor="Black"
            Clicked="OnConnectionButtonClicked"
            HorizontalOptions="End"
            VerticalOptions="Start"
            Grid.Row="0"
            Margin="0,10,10,0"
            Shadow="{Shadow Brush=Black, Opacity=0.3, Radius=5, Offset='2,2'}" />
        <!-- Location button overlay -->
        <Button 
            Text="📍"
            FontSize="20"
            WidthRequest="50"
            HeightRequest="50"
            CornerRadius="25"
            BackgroundColor="White"
            TextColor="Black"
            Clicked="OnLocationButtonClicked"
            HorizontalOptions="End"
            VerticalOptions="Start"
            Grid.Row="0"
            Margin="0,80,10,0"
            Shadow="{Shadow Brush=Black, Opacity=0.3, Radius=5, Offset='2,2'}" />
        <Button 
            Text="💬"
            FontSize="20"
            WidthRequest="50"
            HeightRequest="50"
            CornerRadius="25"
            BackgroundColor="White"
            TextColor="Black"
            Clicked="OnToggleChatClicked"
            HorizontalOptions="End"
            VerticalOptions="Start"
            Grid.Row="0"
            Margin="0,150,10,0"
            Shadow="{Shadow Brush=Black, Opacity=0.3, Radius=5, Offset='2,2'}" />
        <!-- Settings button overlay -->
        <Button 
            Text="⚙️"
            FontSize="20"
            WidthRequest="50"
            HeightRequest="50"
            CornerRadius="25"
            BackgroundColor="White"
            TextColor="Black"
            Clicked="OnSettingsClicked"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            Grid.Row="0"
            Margin="0,80,10,0"
            Shadow="{Shadow Brush=Black, Opacity=0.3, Radius=5, Offset='2,2'}" />
            </Grid>
</ContentPage>