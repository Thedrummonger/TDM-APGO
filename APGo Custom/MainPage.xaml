<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APGo_Custom.MainPage">

    <Grid>
        <WebView x:Name="MapWebView" />

        <!-- Connection status button -->
        <Button 
            x:Name="ConnectionButton"
            Text="🔴"
            FontSize="20"
            WidthRequest="50"
            HeightRequest="50"
            CornerRadius="25"
            BackgroundColor="White"
            TextColor="Black"
            Clicked="OnConnectionButtonClicked"
            HorizontalOptions="End"
            VerticalOptions="Start"
            Margin="0,10,10,0"
            Shadow="{Shadow Brush=Black, Opacity=0.3, Radius=5, Offset='2,2'}" />

        <!-- Location button overlay -->
        <Button 
            Text="📍"
            FontSize="20"
            WidthRequest="50"
            HeightRequest="50"
            CornerRadius="25"
            BackgroundColor="White"
            TextColor="Black"
            Clicked="OnLocationButtonClicked"
            HorizontalOptions="End"
            VerticalOptions="Start"
            Margin="0,80,10,0"
            Shadow="{Shadow Brush=Black, Opacity=0.3, Radius=5, Offset='2,2'}" />
    </Grid>

</ContentPage>